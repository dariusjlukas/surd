{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "surd",
  "version": "0.6.0",
  "identifier": "com.dariusjlukas.surd",
  "build": {
    "beforeDevCommand": "npm run build:wasm && npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build:wasm && npm run build && npm run build:offline-docs",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "surd",
        "width": 1100,
        "height": 760,
        "minWidth": 640,
        "minHeight": 480
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Education",
    "shortDescription": "Exact-by-default mathematical scratchpad",
    "longDescription": "surd is a correct-by-default mathematical scratchpad: an exact computer-algebra engine with plotting, signal/DSP tools, and a notebook UI. Runs fully offline.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "rpm": {
        "depends": ["webkit2gtk4.1", "gtk3"]
      }
    }
  }
}
